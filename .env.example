# ============================================================
# VendorVigil — Environment Variables
# ⚠️  NEVER commit real API keys! This file is for documentation.
# ============================================================

# ============================================================
# BAND CREDENTIALS (Remote Agents)
# ============================================================
# How Band authentication works:
#   Each Remote Agent you create at https://app.band.ai gets its
#   own unique API Key — Band does NOT use a single master key.
#   You need BOTH an Agent ID and its corresponding Agent API Key
#   for every one of the 7 agents below.
#
# Steps:
#   1. Go to https://app.band.ai → Agents → Create Remote Agent
#   2. Create 7 agents matching the handles below
#   3. Copy each agent's ID and API Key (Band shows both)
#   4. Paste them into the matching slots below
#
# Note: The Band Chat Room also needs a ROOM_ID — this identifies
#       which chat room agents coordinate in.
# ============================================================

# Band Room (shared coordination space)
BAND_ROOM_ID=eb050099-8310-4e65-b9fb-b2d76639c67c

# Agent 1: @KoordinatorVendor (LangGraph router)
BAND_VENDOR_COORDINATOR_ID=
BAND_VENDOR_COORDINATOR_KEY=

# Agent 2: @PemeriksaKeamanan (Security reviewer)
BAND_SECURITY_REVIEWER_ID=
BAND_SECURITY_REVIEWER_KEY=

# Agent 3: @PemeriksaPrivasi (Privacy reviewer)
BAND_PRIVACY_REVIEWER_ID=
BAND_PRIVACY_REVIEWER_KEY=

# Agent 4: @PemeriksaFinansial (Financial reviewer)
BAND_FINANCIAL_REVIEWER_ID=
BAND_FINANCIAL_REVIEWER_KEY=

# Agent 5: @PenilaiRisiko (Risk scorer)
BAND_RISK_SCORER_ID=
BAND_RISK_SCORER_KEY=

# Agent 6: @PencatatAudit (Audit logger)
BAND_AUDIT_LOGGER_ID=
BAND_AUDIT_LOGGER_KEY=

# Agent 7: @PenyusunLaporan (Report compiler)
BAND_REPORT_COMPILER_ID=
BAND_REPORT_COMPILER_KEY=

# === AI/ML API ===
# Get key at https://aimlapi.com/app/keys
# Credit: $10 via lablab.ai hackathon partner program
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL_MAIN=google/gemini-3-flash-preview
AIML_MODEL_REASONING=openai/gpt-5-2
AIML_MODEL_COMPLIANCE=anthropic/claude-sonnet-4.5

# === FEATHERLESS AI ===
# Get key at https://featherless.ai/account/api-keys
# Credit: $25 via lablab.ai, promo code BOA26
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL_AUDIT=deepseek-ai/DeepSeek-V4-Pro
FEATHERLESS_MODEL_SECOND_OPINION=Qwen/Qwen3.6-35B-A3B
FEATHERLESS_MODEL_FINANCIAL=deepseek-ai/DeepSeek-V4-Flash

# === MOCK MODE ===
# Set to "true" to use deterministic mock outputs (no API calls)
# Set to "false" to use real AI/ML API and Featherless
USE_MOCK_PROVIDER=true


# ===========================================================================
# HONEST PROVIDER CONFIGURATION
# Each provider has its own KEY and BASE_URL. No aliasing.
# ===========================================================================

# AI/ML API (primary partner)
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1

# Featherless AI (primary partner)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_BASE_URL=

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# DeepSeek (standalone provider)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# DigitalOcean Inference (standalone provider)
DIGITALOCEAN_INFERENCE_API_KEY=
DIGITALOCEAN_INFERENCE_BASE_URL=
